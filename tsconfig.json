{
  "compilerOptions": {
    "target": "es5", 
    "module": "commonjs", 
    "declaration": true, 
    "outDir": "./dist", 
    "strict": true, 
    "esModuleInterop": true, 
    "skipLibCheck": true, 
    "forceConsistentCasingInFileNames": true, 
    "lib": ["es2015", "dom"], 
    "jsx": "react-native" 
  },
  "include": ["src"], 
  "exclude": ["node_modules", "**/__tests__/*"]
}
