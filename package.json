    "prepublishOnly": "npm run lint && npm run build",
    "prebuild": "npm run format"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akshay-khapare/akshay-khapare-react-native-responsive-size.git"
  },
