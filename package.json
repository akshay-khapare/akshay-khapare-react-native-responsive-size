    "performance",
    "optimized",
    "react-native",
    "responsive",
    "sizing",
    "dimensions",
    "font-size",
    "width",
    "height",
    "radius",
    "spacing",
    "responsive-layout",
    "react-native-responsive"
  ],
  "author": "Akshay Khapare",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/akshay-khapare/akshay-khapare-react-native-responsive-size/issues"
